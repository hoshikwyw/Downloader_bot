# --- Telegram bot config ---
# 1. Open Telegram, talk to @BotFather, send /newbot, follow the steps.
# 2. Paste the token it gives you below.
BOT_TOKEN=

# Your numeric Telegram user ID, so only YOU can use the bot.
# To find it: run the bot, then send it /id and it will reply with your ID.
# Multiple IDs allowed (comma or space separated).
# Leave EMPTY to allow everyone (NOT recommended).
ALLOWED_USER_IDS=

# --- Optional: self-hosted Bot API server (M4) to send files up to 2 GB ---
# Leave LOCAL_API_BASE empty to use Telegram's cloud API (50 MB limit).
# To enable 2 GB uploads: get api_id/api_hash from https://my.telegram.org,
# put them below, run `docker compose up -d`, then set:
#   LOCAL_API_BASE=http://localhost:8081
LOCAL_API_BASE=

# These two are used by docker-compose to run the Bot API server (NOT by the bot
# itself). Get them from https://my.telegram.org -> API development tools.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
